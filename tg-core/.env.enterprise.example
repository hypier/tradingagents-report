# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=
# OPENAI_API_VERSION=2024-10-21  # optional, required for non-v1 API


# ==================== 市场数据源路由 ====================
# disabled 表示继续使用原有默认链：TradingView -> yfinance -> Alpha Vantage
TRADINGAGENTS_CN_DATA_VENDORS=disabled
TRADINGAGENTS_US_DATA_VENDORS=disabled

# A 股启用示例，顺序即优先级
# TRADINGAGENTS_CN_DATA_VENDORS=akshare,baostock,tushare,pandaai

# 美股启用示例
# TRADINGAGENTS_US_DATA_VENDORS=tradingview,yfinance,finnhub,pandaai,alpha_vantage

# ==================== PandaAI ====================
# SDK：https://pypi.org/project/panda-data/
# 账号、密码和服务地址需向 PandaAI 服务提供方或管理员申请
PANDAAI_USERNAME=
PANDAAI_PASSWORD=

# 留空时使用 SDK 默认服务地址
PANDAAI_BASE_URL=

# 格式示例：
# PANDAAI_USERNAME=your_pandaai_username
# PANDAAI_PASSWORD=your_pandaai_password
# PANDAAI_BASE_URL=https://pandaai.example.com

# ==================== Tushare ====================
# 注册：https://tushare.pro/register
# Token：https://tushare.pro/user/token
TUSHARE_TOKEN=

# 格式示例：
# TUSHARE_TOKEN=your_tushare_token

# ==================== Finnhub ====================
# 注册：https://finnhub.io/register
# API 控制台：https://finnhub.io/dashboard
FINNHUB_API_KEY=

# 格式示例：
# FINNHUB_API_KEY=your_finnhub_api_key