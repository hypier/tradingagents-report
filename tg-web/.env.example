PORT=8787
VITE_API_BASE_URL=/api
DATABASE_URL=postgresql://127.0.0.1:5432/tradingagents
REDIS_URL=redis://127.0.0.1:6379
CORE_API_URL=http://127.0.0.1:8000
# Leave empty for local development: pnpm dev loads ../tg-core/.env and uses
# its TRADINGAGENTS_API_KEY. Set this only when Core uses a different token.
CORE_API_KEY=
# Optional: enables server-side TradingView asset search for company names and logos.
TRADINGVIEW_RAPIDAPI_KEY=
