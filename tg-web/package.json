{
  "name": "tg-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "tsx watch src/runtimes/node.ts",
    "dev:web": "vite",
    "build": "vite build",
    "build:node": "tsup src/runtimes/node.ts --format esm --out-dir dist/backend",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "test": "pnpm test:unit && pnpm test:worker",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:worker": "vitest run --project worker",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.0",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.8.0",
    "ioredis": "^5.7.0",
    "lucide-react": "^0.468.0",
    "pg": "^8.16.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.8.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20250726.0",
    "@eslint/js": "^9.33.0",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.0",
    "eslint": "^9.33.0",
    "globals": "^16.3.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.6.0",
    "tailwindcss": "^4.1.0",
    "testcontainers": "^11.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.39.0",
    "vite": "^6.2.6",
    "vitest": "^3.2.0"
  }
}
