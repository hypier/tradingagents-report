# =============================================================================
# tg-web 环境变量模板（复制为 .env 后填写）
# - 必填：启动 Node BFF 时 Zod 会校验
# - 可省略：见各字段注释
# =============================================================================

# [必填] Node BFF 监听端口；Vite 把 /api 代理到这里
PORT=8788

# [必填] Clerk 浏览器端 publishable key（BFF 经 /api/public-config 下发；Vite 本地作回退）
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# [必填] Clerk 服务端 secret key（仅 BFF）
CLERK_SECRET_KEY=sk_test_replace_me

# [必填] 允许的前端 Origin 列表（逗号分隔），须与浏览器地址栏一致
CLERK_AUTHORIZED_PARTIES=http://localhost:5173,http://127.0.0.1:5173

# [必填] 与 Core 共用的 PostgreSQL（需含用户名和密码；db:migrate 只读此值）
DATABASE_URL=postgresql://tradingagents:replace-with-postgres-password@127.0.0.1:5432/tradingagents

# [必填] Node 运行时缓存用的 Redis
REDIS_URL=redis://127.0.0.1:6379

# [必填] Core HTTP API 地址
CORE_API_URL=http://127.0.0.1:8000

# [必填·本地建议显式填写] 调用 Core 的 Bearer API Key。
# 与 tg-core/.env 的 TRADINGAGENTS_API_KEY 保持同一值即可，互不取消对方鉴权。
# （代码里留空时仍可回退读取 TRADINGAGENTS_API_KEY，但不推荐，容易误解。）
CORE_API_KEY=replace-with-a-core-api-key

# [可省略] 对外公开 Origin（Stripe Checkout / Portal / webhook 回调）。
# 不设则使用 CLERK_AUTHORIZED_PARTIES 的第一项。
APP_BASE_URL=http://localhost:5173

# [可省略] 前端 API 基路径；当前代码写死同域 /api，此变量未被读取。
# VITE_API_BASE_URL=/api

# [可省略] 日志级别，默认 info（debug | info | warn | error）
# LOG_LEVEL=info

# [可省略] Stripe；不配则计费页显示未配置，其余功能可用
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# [可省略] 加密存储 LLM 提供商 API Key 时需要（Base64 的 32 字节密钥）
# 生成：openssl rand -base64 32
BILLING_CONFIG_ENCRYPTION_KEY=

# [可省略] TradingView RapidAPI；不配则服务端市场搜索/公司名 logo 不可用
TRADINGVIEW_RAPIDAPI_KEY=
