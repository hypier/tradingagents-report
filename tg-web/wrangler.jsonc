{
  "name": "tg-web",
  "main": "./src/runtimes/cloudflare.ts",
  "compatibility_date": "2025-09-06",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist/frontend",
    "binding": "ASSETS",
    "html_handling": "none",
    "not_found_handling": "none",
    "run_worker_first": true,
  },
  // Replace these binding IDs in the named environments before deployment.
  "kv_namespaces": [
    { "binding": "CACHE_KV", "id": "REPLACE_WITH_KV_NAMESPACE_ID" },
  ],
  // Set WRANGLER_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE locally; the ID is required for deployment.
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "REPLACE_WITH_HYPERDRIVE_ID",
    },
  ],
  "env": {
    // Development and production must each set CACHE_KV and HYPERDRIVE binding IDs at deployment time.
    "development": {},
    "production": {},
  },
}
