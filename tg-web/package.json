{
  "name": "tg-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "ensure:env": "test -f .env || cp .env.example .env",
    "predev": "pnpm ensure:env",
    "predev:api": "pnpm ensure:env",
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "tsx watch --env-file=../tg-core/.env --env-file=.env src/runtimes/node.ts",
    "dev:web": "vite",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/backend/database/migrate-cli.ts",
    "db:backfill-display": "tsx src/backend/database/backfill-job-display.ts",
    "build": "vite build",
    "build:node": "tsup --format esm --out-dir dist/backend --entry.node=src/runtimes/node.ts --entry.migrate-cli=src/backend/database/migrate-cli.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "test": "pnpm test:unit && pnpm test:worker",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:worker": "vitest run --project worker",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@clerk/backend": "^3.11.6",
    "@clerk/react": "^6.12.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.3.0",
    "@fontsource/noto-sans-mono": "^5.3.0",
    "@fontsource/noto-sans-sc": "^5.3.0",
    "@tanstack/react-query": "^5.90.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.8.0",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "ioredis": "^5.7.0",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^0.468.0",
    "next-themes": "^0.4.6",
    "pg": "^8.16.0",
    "radix-ui": "^1.6.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.10",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.8.0",
    "recharts": "3.8.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "stripe": "^22.3.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20250726.0",
    "@eslint/js": "^9.33.0",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.0",
    "drizzle-kit": "0.31.4",
    "eslint": "^9.33.0",
    "globals": "^16.3.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.6.0",
    "tailwindcss": "^4.1.0",
    "testcontainers": "^11.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.39.0",
    "vite": "^6.2.6",
    "vitest": "^3.2.0"
  }
}
