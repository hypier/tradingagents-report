PORT=8787
VITE_API_BASE_URL=/api
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_AUTHORIZED_PARTIES=http://localhost:5173,http://127.0.0.1:5173
# Optional Stripe subscription billing. Keep secrets server-side.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: enables administrators to store Stripe credentials encrypted in
# PostgreSQL. Generate with: openssl rand -base64 32
BILLING_CONFIG_ENCRYPTION_KEY=
# Public origin used in Stripe Checkout, Customer Portal, and webhook URLs.
APP_BASE_URL=http://localhost:5173
# Shared PostgreSQL used by Core and tg-web. Include username + password.
DATABASE_URL=postgresql://tradingagents:replace-with-postgres-password@127.0.0.1:5432/tradingagents
REDIS_URL=redis://127.0.0.1:6379
CORE_API_URL=http://127.0.0.1:8000
# Leave empty for local development: pnpm dev loads ../tg-core/.env and uses
# its TRADINGAGENTS_API_KEY. Set this only when Core uses a different token.
CORE_API_KEY=
# Optional: enables server-side TradingView asset search for company names and logos.
TRADINGVIEW_RAPIDAPI_KEY=
